#!/bin/bash
# Launch Claude Code from source
SCRIPT="$0"
# Resolve symlinks
while [ -L "$SCRIPT" ]; do
  DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"
  SCRIPT="$(readlink "$SCRIPT")"
  [[ "$SCRIPT" != /* ]] && SCRIPT="$DIR/$SCRIPT"
done
DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"
exec bun --preload "$DIR/preload.ts" "$DIR/entrypoints/cli.tsx" "$@"
